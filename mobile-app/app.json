{
  "expo": {
    "name": "GummyText - Second Phone Number",
    "slug": "gummytext",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "gummytext",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0415"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gummytext.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "GummyText needs microphone access for voice calls and voice messages.",
        "NSContactsUsageDescription": "GummyText can sync your contacts to make calling and messaging easier.",
        "NSCameraUsageDescription": "GummyText needs camera access for video calls and sending photos.",
        "NSPhotoLibraryUsageDescription": "GummyText needs photo library access to send and receive images.",
        "UIBackgroundModes": ["audio", "voip"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0415"
      },
      "package": "com.gummytext.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#D946EF"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow GummyText to access your camera for video calls."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow GummyText to access your photos.",
          "savePhotosPermission": "Allow GummyText to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow GummyText to access your contacts."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow GummyText to access your microphone for calls."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-expo-project-id"
      }
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    }
  }
}
